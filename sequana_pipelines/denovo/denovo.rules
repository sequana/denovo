"""Short Read De Novo assembly pipeline"""
from sequana_pipetools.snaketools import PipelineManager


configfile: "config.yaml"


manager = PipelineManager("denovo", config, schema="schema.yaml")


rule denovo:
    input:
        "multiqc/multiqc_report.html",
        ".sequana/rulegraph.svg",


def requested_output(manager):
    """Resolve all needed output knowing the user config."""
    output_list = [
        expand("{sample}/quast/quast.done", sample=manager.samples),
        expand("{sample}/summary/{sample}.json", sample=manager.samples),
    ]
    if config["sequana_coverage"]["do"]:
        output_list += [
            expand(
                "{sample}/sequana_coverage/sequana_coverage.html",
                sample=manager.samples,
            )
        ]
    if config["prokka"]["do"]:
        output_list += [expand("{sample}/prokka/{sample}.gff", sample=manager.samples)]
    if config["freebayes"]["do"]:
        output_list += [
            expand("{sample}/vcf_filter/{sample}.filter.vcf", sample=manager.samples)
        ]
    if config["busco"]["do"]:
        output_list += [expand("{sample}/busco/", sample=manager.samples)]
    if config["blast"]["do"]:
        output_list += [expand("{sample}/blast/{sample}.tsv", sample=manager.samples)]
    if config["checkm"]["do"]:
        output_list += [expand("{sample}/checkm/{sample}.marker_pos_plot.png", sample=manager.samples)]

    return output_list


# Function that define pipeline path
def get_raw_fastq(wildcards):
    """Get raw data"""
    return manager.samples[wildcards.sample]


def get_normalized_fastq(wildcards):
    """Get normalized data"""
    sample = wildcards.sample
    if config["digital_normalisation"]["do"]:
        if manager.paired:
            return [
                f"{sample}/digital_normalisation/{sample}_R{i}_.dn.fastq"
                for i in (1, 2)
            ]
        return [f"{sample}/digital_normalisation/{sample}_R1_.dn.fastq"]
    return get_raw_fastq(wildcards)


def get_assembly(wildcards):
    """Get assembly"""
    sample = wildcards.sample
    if config["assembler"] == "unicycler":
        return f"{sample}/unicycler/{sample}.fasta"
    return f"{sample}/spades/{sample}.scaffolds.fasta"


def get_markdup_bam(wildcards):
    """Get markdup bam file"""
    sample = wildcards.sample
    if config["sambamba_markdup"]["do"]:
        return f"{sample}/sambamba_markdup/{sample}.sorted.bam"
    return f"{sample}/bwa/{sample}.sorted.bam"


def get_filtered_bam(wildcards):
    """Get filtered bam file"""
    sample = wildcards.sample
    if config["sambamba_filter"]["do"]:
        return f"{sample}/sambamba_filter/{sample}.sorted.bam"
    return get_markdup_bam(wildcards)


def get_sequana_coverage_input(config):
    input_file = {
        "bed": "{sample}/double_bed/{sample}.bed",
        "fasta": "{sample}/seqkit_filter/{sample}.fasta",
    }
    if config["prokka"]["do"]:
        input_file["gff"] = "{sample}/prokka/{sample}.gff"
    return input_file


def create_prokka_option(config):
    """ create options with default prokka options.
    """
    kingdom = config.get("kingdom", "Bacteria")
    genus = config.get("genus", "genus")
    species = config.get("species", "species")
    return f"--kingdom {kingdom} --genus {genus} --species {species} {config['options']}"


def get_rulegraph_mapper(config):
    mapper = {"quast": "../quast/icarus.html"}
    if config["sequana_coverage"]["do"]:
        mapper.update({"sequana_coverage": "../sequana_coverage/sequana_coverage.html"})
    if config["freebayes"]["do"]:
        mapper.update({"freebayes_vcf_filter": "../variant_calling.html"})
    return mapper


# rules
rule digital_normalisation:
    input:
        fastq=get_raw_fastq,
    output:
        fastq=[
            f"{{sample}}/digital_normalisation/{{sample}}_R{i}_.dn.fastq"
            for i in range(1, 2 + manager.paired)
        ],
    log:
        "{sample}/logs/digital_normalisation.log",
    params:
        ksize=config["digital_normalisation"]["ksize"],
        cutoff=config["digital_normalisation"]["cutoff"],
        m=config["digital_normalisation"]["max_memory_usage"],
        options=config["digital_normalisation"]["options"],
        paired=manager.paired,
        r2_in=lambda wildcards, input: input.fastq[1] if manager.paired else "",
        out_r1=lambda wildcards, output: output.fastq[0],
        out_r2=lambda wildcards, output: output.fastq[1] if manager.paired else "",
    threads:
        config["digital_normalisation"]["threads"]
    container:
        config["apptainers"]["digital_normalisation"]
    resources:
        **config["digital_normalisation"]["resources"],
    shell:
        """
        graph={wildcards.sample}/digital_normalisation/{wildcards.sample}.graph

        r1={input.fastq[0]}
        [[ "$r1" == *.gz ]] && unpigz -p {threads} -fk $r1 && r1="${{r1%.gz}}"

        if [ "{params.paired}" == "True" ]
        then
            r2={params.r2_in}
            [[ "$r2" == *.gz ]] && unpigz -p {threads} -fk $r2 && r2="${{r2%.gz}}"
            prefix=$(basename $r1 .fastq)

            interleave-reads.py $r1 $r2 --output $prefix.pe >{log} 2>&1
            normalize-by-median.py --paired --ksize {params.ksize} \
                --cutoff {params.cutoff} -M {params.m} {params.options} \
                --savegraph $graph $prefix.pe --output $prefix.pe.keep >>{log} 2>&1
            filter-abund.py --threads {threads} -V $graph \
                $prefix.pe.keep --output $prefix.pe.filter >>{log} 2>&1
            extract-paired-reads.py $prefix.pe.filter \
                --output-paired $prefix.pe --output-single $prefix.orphans >>{log} 2>&1
            split-paired-reads.py $prefix.pe -1 {params.out_r1} -2 {params.out_r2} >>{log} 2>&1
            rm -f $prefix.pe $prefix.pe.filter $prefix.pe.keep $prefix.orphans
        else
            prefix=$(basename $r1 .fastq)
            normalize-by-median.py --ksize {params.ksize} \
                --cutoff {params.cutoff} -M {params.m} {params.options} \
                --savegraph $graph $r1 --output $prefix.se.keep >{log} 2>&1
            filter-abund.py --threads {threads} -V $graph \
                $prefix.se.keep --output $prefix.se.filter >>{log} 2>&1
            mv $prefix.se.filter {params.out_r1}
            rm -f $prefix.se.keep
        fi
        rm -f $graph
        """


rule spades:
    input:
        fastq=get_normalized_fastq,
    output:
        contigs="{sample}/spades/{sample}.contigs.fasta",
        scaffolds="{sample}/spades/{sample}.scaffolds.fasta",
    params:
        k=config["spades"]["k"],
        preset=config["spades"]["preset"],
        options=config["spades"]["options"],
        memory=config["spades"]["memory"],
    log:
        "{sample}/logs/spades.log",
    threads:
        config["spades"]["threads"]
    container:
        config["apptainers"]["spades"]
    resources:
        **config["spades"]["resources"],
    shell:
        manager.get_shell("spades/run", "v1")


rule unicycler:
    input:
        fastq=get_normalized_fastq,
    output:
        "{sample}/unicycler/{sample}.fasta"
    params:
        mode=config["unicycler"]["mode"],
        options=config["unicycler"]["options"],
    log:
        "{sample}/logs/unicycler.log",
    threads:
        config["unicycler"]["threads"]
    container:
        config["apptainers"]["unicycler"]
    resources:
        **config["unicycler"]["resources"],
    shell:
        manager.get_shell("unicycler/run", "v1")

rule quast:
    input:
        fastq=get_normalized_fastq,
        assembly=get_assembly,
    output:
        "{sample}/quast/quast.done",
    log:
        "{sample}/logs/quast.log",
    params:
        reference=config["quast"]["reference_file"],
        annotation=config["quast"]["annotation_file"],
        options=config["quast"]["options"],
    threads:
        config["quast"]["threads"]
    container:
        config["apptainers"]["quast"]
    resources:
        **config["quast"]["resources"],
    shell:
        manager.get_shell("quast/run", "v1")


rule seqkit_filter:
    input:
        get_assembly,
    output:
        "{sample}/seqkit_filter/{sample}.fasta",
    log:
        "{sample}/logs/seqkit_filter.log",
    params:
        config["seqkit_filter"]["threshold"],
    container:
        config["apptainers"]["seqkit"]
    shell:
        """
        seqkit seq -i --id-regexp "^(.+)_cov.*" --min-len {params} {input} --out-file {output} > {log} 2>&1
        """


rule prokka:
    input:
        assembly="{sample}/seqkit_filter/{sample}.fasta",
    output:
        "{sample}/prokka/{sample}.gff",
    log:
        "{sample}/logs/prokka.log",
    params:
        options=create_prokka_option(config["prokka"])
    threads:
        config["prokka"]["threads"]
    container:
        config["apptainers"]["prokka"]
    resources:
        **config["prokka"]["resources"],
    shell:
        manager.get_shell("prokka/run", "v1")


rule busco:
    input:
        "{sample}/seqkit_filter/{sample}.fasta",
    output:
       directory("{sample}/busco"),
    log:
        "{sample}/logs/busco.log",
    params:
        mode="genome",
        lineage=config["busco"]["lineage"],
        short_summary_filename="short_summary_{sample}.txt",
        options=config["busco"]["options"],
    threads:
        config["busco"]["threads"]
    container:
        config["apptainers"]["busco"]
    resources:
        **config["busco"]["resources"],
    shell:
        manager.get_shell("busco/run", "v1")


rule checkm_marker:
    output:
        marker="marker"
    log:
        "logs/checkm_marker.log"
    threads:
         1
    container:
        config['apptainers']['checkm']
    params:
        taxon_rank=config["checkm"]["taxon_rank"],
        taxon_name=config["checkm"]["taxon_name"]
    resources:
        **config["checkm"]["resources"],
    shell:
        """
        checkm taxon_set {params.taxon_rank} "{params.taxon_name}" {output.marker} >{log} 2>&1
        """


rule checkm:
    input:
        fasta="{sample}/sorted_contigs/{sample}.fasta",
        marker=rules.checkm_marker.output.marker
    output:
        results="{sample}/checkm/results.txt",
        png="{sample}/checkm/{sample}.marker_pos_plot.png"
    log:
        "{sample}/logs/checkm.log"
    params:
        taxon_rank=config["checkm"]["taxon_rank"],
        taxon_name=config["checkm"]["taxon_name"]
    threads:
        config['checkm']['threads']
    container:
        config['apptainers']['checkm']
    resources:
        **config["checkm"]["resources"],
    shell:
        """
        checkm analyze {input.marker} {wildcards.sample}/sorted_contigs/ {wildcards.sample}/checkm -x fasta -t {threads} >{log} 2>&1
        checkm qa marker {wildcards.sample}/checkm/ -f {output.results} >>{log} 2>&1
        checkm marker_plot {wildcards.sample}/checkm/ {wildcards.sample}/sorted_contigs {wildcards.sample}/checkm/ -x fasta >>{log} 2>&1
        """


rule bwa_index:
    input:
        reference="{sample}/seqkit_filter/{sample}.fasta",
    output:
        "{sample}/seqkit_filter/{sample}.fasta.bwt",
        "{sample}/seqkit_filter/{sample}.fasta.fai",
    log:
        "{sample}/logs/bwa_index.log",
    params:
        index_algorithm=config["bwa"]["index_algorithm"],
        options=config["bwa_index"]["options"],
    threads:
        2
    container:
        config['apptainers']['bwa']
    resources:
        **config["bwa_index"]["resources"],
    shell:
        manager.get_shell("bwa/build", "v1")


rule bwa:
    input:
        fastq=get_raw_fastq,
        reference="{sample}/seqkit_filter/{sample}.fasta",
        bwt="{sample}/seqkit_filter/{sample}.fasta.bwt",
        fai="{sample}/seqkit_filter/{sample}.fasta.fai",
    output:
        sam=temp("{sample}/bwa/{sample}.sam"),
        bam=temp("{sample}/bwa/{sample}.bam"),
        sorted="{sample}/bwa/{sample}.sorted.bam",
    log:
        "{sample}/logs/bwa_mem.log",
    params:
        options=config["bwa"]["options"],
    threads:
        config["bwa"]["threads"]
    container:
        config['apptainers']["bwa"]
    resources:
        **config["bwa"]["resources"],
    shell:
        manager.get_shell("bwa/align", "v2")


rule sambamba_markdup:
    input:
        bam="{sample}/bwa/{sample}.sorted.bam",
    output:
        bam="{sample}/sambamba_markdup/{sample}.sorted.bam",
    log:
        "{sample}/logs/sambamba_markdup.log",
    params:
        remove_duplicates=config["sambamba_markdup"]["remove"],
        tmp_directory=config["sambamba_markdup"]["tmp_directory"] or "./tmp",
        options="",
    container:
        config['apptainers']["sambamba"]
    resources:
        **config["sambamba_markdup"]["resources"],
    shell:
        manager.get_shell("sambamba_markdup/run", "v1")


rule sambamba_filter:
    input:
        bam=get_markdup_bam,
    output:
        bam="{sample}/sambamba_filter/{sample}.sorted.bam",
    log:
        "{sample}/logs/sambamba_filter.log",
    params:
        threshold=config["sambamba_filter"]["threshold"],
        options="",
    container:
        config['apptainers']["sambamba"]
    resources:
        **config["sambamba_filter"]["resources"],
    shell:
        manager.get_shell("sambamba_filter/run", "v1")


rule freebayes:
    input:
        bam=get_filtered_bam,
        ref="{sample}/seqkit_filter/{sample}.fasta",
    output:
        vcf="{sample}/freebayes/{sample}.raw.vcf",
    log:
        "{sample}/logs/freebayes.log",
    params:
        ploidy=config["freebayes"]["ploidy"],
        options=config["freebayes"]["options"],
    container:
        config['apptainers']["freebayes"]
    resources:
        **config["freebayes"]["resources"],
    shell:
        manager.get_shell("freebayes/run", "v1")


rule freebayes_vcf_filter:
    input:
        "{sample}/freebayes/{sample}.raw.vcf",
    output:
        vcf="{sample}/vcf_filter/{sample}.filter.vcf",
        csv="{sample}/vcf_filter/{sample}.filter.csv",
        html="{sample}/variant_calling.html",
    params:
        filter_dict=config["vcf_filter"],
    #container:
    #    config['apptainers']["freebayes"]
    run:
        from sequana.freebayes_vcf_filter import VCF_freebayes
        from sequana.modules_report.variant_calling import VariantCallingModule
        from sequana.utils import config as seq_config

        v = VCF_freebayes(input[0])
        filter_v = v.filter_vcf(params["filter_dict"])
        filter_v.to_vcf(output.vcf)
        filter_v.to_csv(output.csv)

        report_dir = output.html.rsplit("/", 1)[0]
        seq_config.output_dir = report_dir
        VariantCallingModule(filter_v)


if config["sequana_coverage"]["do"]:


    rule bedtools_depth:
        input:
            "{sample}/sambamba_filter/{sample}.sorted.bam",
        output:
            "{sample}/bedtools_depth/{sample}.bed"
        log:
            "{sample}/bedtools_depth/{sample}.log"
        resources:
            **config["sequana_coverage"]["resources"]
        container:
            config['apptainers']['bedtools']
        shell:
            """
            bedtools genomecov -d -ibam {input} > {output} 2>{log}
            """


    rule samtools_depth:
        input:
            bam="{sample}/sambamba_filter/{sample}.sorted.bam",
        output:
            "{sample}/samtools_depth/{sample}.bed",
        log:
            "{sample}/logs/samtools_depth.log",
        params:
            options="",
        container:
            config['apptainers']['samtools']
        resources:
            **config["sequana_coverage"]["resources"],
        shell:
            manager.get_shell("samtools_depth/run", "v1")

    rule double_bed:
        input:
            bed1="{sample}/bedtools_depth/{sample}.bed",
            bed2="{sample}/samtools_depth/{sample}.bed"
        output:
            "{sample}/double_bed/{sample}.bed"
        run:
            with open(input.bed1) as fin1, open(input.bed2) as fin2, open(output[0], "w") as fout:
                for line1, line2 in zip(fin1, fin2):
                    name1, pos1, count1 = line1.split()
                    name2, pos2, count2 = line2.split()
                    assert name1==name2
                    assert pos1==pos2
                    fout.write(f"{name1}\t{pos1}\t{count1}\t{count2}\n")


    rule sequana_coverage:
        input:
            **get_sequana_coverage_input(config),
        output:
            "{sample}/sequana_coverage/sequana_coverage.html",
        log:
            "{sample}/logs/sequana_coverage.log",
        params:
            annotation="", #config["general"]["annotation_file"],
            circular=config["sequana_coverage"]["circular"],
            chunksize=config["sequana_coverage"]["chunksize"],
            double_threshold=config["sequana_coverage"]["double_threshold"],
            gc_window_size=config["sequana_coverage"]["gc_window_size"],
            high_threshold=config["sequana_coverage"]["high_threshold"],
            low_threshold=config["sequana_coverage"]["low_threshold"],
            mixture_models=config["sequana_coverage"]["mixture_models"],
            output_directory="{sample}/sequana_coverage",
            options=config["sequana_coverage"]["options"],
            window_size=config["sequana_coverage"]["window_size"],
        container:
            config["apptainers"]["sequana_coverage"]
        resources:
            **config["sequana_coverage"]["resources"]
        shell:
            manager.get_shell("sequana_coverage/run", "v1")


rule seqkit_head:
    input:
        "{sample}/seqkit_filter/{sample}.fasta"
    output:
        "{sample}/subset_contigs/{sample}.subset.fasta"
    log:
        "{sample}/logs/seqkit_head.log",
    params:
        n_first = config["seqkit_head"]["n_first"]
    container:
        config['apptainers']["seqkit"]
    shell:
        """
        seqkit head -n {params.n_first} -o {output} {input} > {log} 2>&1
        """


rule blast:
    input:
        query="{sample}/subset_contigs/{sample}.subset.fasta",
        blastdb=config["blast"]["blastdb"],
    output:
        "{sample}/blast/{sample}.tsv"
    log:
        "{sample}/logs/blast.log",
    params:
        blast_type="blastn",
        db_type="nt",
        evalue=config['blast']['evalue'],
        outfmt=config['blast']['outfmt'],
        options=config['blast']['options']
    threads:
        config['blast']['threads']
    resources:
        **config["blast"]["resources"],
    container: config["apptainers"]["blast"]
    shell:
        manager.get_shell("blast/blast", "v1")


rule rulegraph:
    input:
        workflow.snakefile,
    output:
        "rulegraph/rulegraph.dot",
    params:
        configname="config.yaml",
        mapper=get_rulegraph_mapper(config),
        required_local_files=["schema.yaml"],
    run:
        manager.get_run("rulegraph/run", "v1")(input, output, params)


rule dot2svg:
    input:
        "rulegraph/rulegraph.dot"
    output:
        ".sequana/rulegraph.svg"
    container:
        config['apptainers']['graphviz']
    shell:
        manager.get_shell("graphviz/dot2svg", "v1")



# ======================================================================= summary
# create a json file that summarise information of your pipeline
# they must be complete in the onsuccess block
rule summary:
    input:
        outputs=get_assembly,
        html=[],
        rulegraph=".sequana/rulegraph.svg",
        snakefile=workflow.snakefile,
        config="config.yaml",
    output:
        json="{sample}/summary/{sample}.json",
    run:
        import json
        import os.path

        summary = {
            "tool": "sequana_summary",
            "inputs": [],
            "outputs": [],
            "html": [os.path.realpath(f) for f in input["html"]],
            "rulegraph": os.path.realpath(input["rulegraph"]),
            "requirements": "",
            "snakefile": os.path.realpath(input["snakefile"]),
            "config": os.path.realpath(input["config"]),
            "name": "denovo",
        }
        js = json.dumps(summary, indent=4, sort_keys=True)
        with open(output["json"], "w") as fp:
            fp.write(js)


# =============================================================== multiqc
rule multiqc:
    input:
        requested_output(manager),
    output:
        "multiqc/multiqc_report.html",
    params:
        options=config["multiqc"]["options"],
        input_directory=config["multiqc"]["input_directory"],
        config_file=config['multiqc']['config_file'],
        modules=config["multiqc"]["modules"],
    log:
        "multiqc/multiqc.log",
    container:
        config["apptainers"]["multiqc"]
    shell:
        manager.get_shell("multiqc/run", "v1")


# these rules don't need to be submit on a node.
localrules: rulegraph, dot2svg


onsuccess:
    import base64
    import glob
    import os
    import pandas as pd

    from sequana.utils.datatables_js import DataTable
    from sequana.modules_report.summary import SequanaReport
    from sequana.utils import config as conf
    from sequana import logger

    logger.setLevel("INFO")

    manager.clean_multiqc("multiqc/multiqc_report.html")

    # Metrics for the main summary table (always present in quast output)
    SUMMARY_FIELDS = [
        ("# contigs", "# contigs"),
        ("Total length", "Total length (bp)"),
        ("Largest contig", "Largest contig (bp)"),
        ("N50", "N50"),
        ("GC (%)", "GC (%)"),
    ]
    # Extra metrics shown only in per-sample reports (may be absent)
    EXTRA_FIELDS = [
        ("Avg. coverage depth", "Avg. coverage depth"),
        ("Mapped (%)", "Mapped (%)"),
    ]
    ALL_FIELDS = SUMMARY_FIELDS + EXTRA_FIELDS

    def _parse_quast(report_txt):
        metrics = {col: "N/A" for _, col in ALL_FIELDS}
        with open(report_txt) as fh:
            for line in fh:
                line = line.rstrip()
                if line.startswith("# contigs") and ">=" not in line and "Largest" not in line:
                    metrics["# contigs"] = line.split()[-1]
                elif line.startswith("Largest contig"):
                    metrics["Largest contig (bp)"] = line.split()[-1]
                elif line.startswith("Total length") and ">=" not in line:
                    metrics["Total length (bp)"] = line.split()[-1]
                elif line.startswith("N50"):
                    metrics["N50"] = line.split()[-1]
                elif line.startswith("GC (%)"):
                    metrics["GC (%)"] = line.split()[-1]
                elif line.startswith("Avg. coverage depth"):
                    metrics["Avg. coverage depth"] = line.split()[-1]
                elif line.startswith("Mapped (%)"):
                    metrics["Mapped (%)"] = line.split()[-1]
        return metrics

    def _coverage_images_b64(sample):
        """Return list of (contig_name, base64_png) for all sequana_coverage PNGs."""
        images = []
        for png in sorted(glob.glob(f"{sample}/sequana_coverage/*/coverage.png")):
            contig = os.path.basename(os.path.dirname(png))
            with open(png, "rb") as fh:
                images.append((contig, base64.b64encode(fh.read()).decode("utf-8")))
        return images

    assembler = config["assembler"]
    nsamples = len(manager.samples)

    # ── main summary table ──────────────────────────────────────────────────────
    rows = []
    for sample in sorted(manager.samples):
        report_txt = f"{sample}/quast/report.txt"
        row = {"Sample": sample, "links": f"{sample}/summary.html"}
        metrics = _parse_quast(report_txt) if os.path.exists(report_txt) else {col: "N/A" for _, col in ALL_FIELDS}
        row.update({col: metrics[col] for _, col in SUMMARY_FIELDS})
        rows.append(row)

    cols = ["Sample"] + [col for _, col in SUMMARY_FIELDS] + ["links"]
    df = pd.DataFrame(rows)[cols]
    dt = DataTable(df, "assembly_stats", index=False)
    dt.datatable.datatable_options = {
        "paging": "false",
        "buttons": ["copy", "csv"],
        "bSort": "true",
        "dom": "BRSPfrti",
    }
    dt.datatable.set_links_to_column("links", "Sample")
    js = dt.create_javascript_function()
    htmltable = dt.create_datatable()

    contents = """<h2>General information</h2>
<p>This pipeline assembled <b>{nsamples}</b> sample(s) using <b>{assembler}</b>.
Assembly quality metrics from <a href="https://quast.sourceforge.net">QUAST</a> are shown below.
A full <a href="multiqc/multiqc_report.html">MultiQC report</a> is also available.
Individual per-sample reports are accessible by clicking the sample name.</p>
<hr>
<h2>Assembly statistics</h2>
{js}{htmltable}
""".format(nsamples=nsamples, assembler=assembler, js=js, htmltable=htmltable)

    conf.output_dir = os.path.abspath(".")
    data = manager.getmetadata()
    SequanaReport(data, intro=contents)

    # ── per-sample individual reports ───────────────────────────────────────────
    for sample in manager.samples:
        conf.output_dir = os.path.abspath(sample)
        conf.summary_sections = []

        # Quast stats
        report_txt = f"{sample}/quast/report.txt"
        if os.path.exists(report_txt):
            metrics = _parse_quast(report_txt)
            rows_s = [{"Metric": col, "Value": metrics[col]} for _, col in ALL_FIELDS]
            df_s = pd.DataFrame(rows_s)
            dt_s = DataTable(df_s, f"quast_{sample}", index=False)
            dt_s.datatable.datatable_options = {"paging": "false", "dom": "t"}
            quast_html = dt_s.create_javascript_function() + dt_s.create_datatable()
        else:
            quast_html = "<p>No QUAST report found.</p>"

        sample_intro = f"""<p><a href="../summary.html">&larr; Back to main report</a></p>
<h2>Sample: {sample}</h2>
<h3>Assembly statistics (QUAST)</h3>
<p>Full QUAST report: <a href="quast/report.html">quast/report.html</a> &mdash;
<a href="quast/icarus.html">Icarus browser</a></p>
{quast_html}"""

        # Coverage plots
        if manager.config.sequana_coverage.do:
            images = _coverage_images_b64(sample)
            if images:
                sample_intro += "<h3>Coverage per contig</h3>"
                for contig, b64 in images:
                    sample_intro += (
                        f'<h4>{contig}</h4>'
                        f'<img src="data:image/png;base64,{b64}" style="max-width:100%;" />'
                    )
            sample_intro += f'<p>Full coverage report: <a href="sequana_coverage/sequana_coverage.html">sequana_coverage.html</a></p>'

        # Optional analyses
        links = []
        if manager.config.prokka.do:
            links.append('<a href="prokka/">Prokka annotation</a> (GFF, GenBank)')
        if manager.config.freebayes.do:
            links.append('<a href="vcf_filter/">Variant calls</a>')
        if manager.config.busco.do:
            links.append('<a href="busco/">BUSCO completeness</a>')
        if manager.config.blast.do:
            links.append('<a href="blast/">BLAST results</a>')
        if links:
            sample_intro += "<h3>Additional analyses</h3><ul>" + "".join(f"<li>{l}</li>" for l in links) + "</ul>"

        conf.summary_sections = []
        sample_data = manager.getmetadata()
        SequanaReport(sample_data, intro=sample_intro, workflow=False)

    shell("chmod -R g+w .")
    manager.teardown()
    manager.clean_multiqc(rules.multiqc.output[0])

onerror:
    manager.onerror()
